# ============================================
# RektCoder — Memecoin Sniper Bot
# Environment variables — fill in your keys
# ============================================
#
# 1. Copy this file and rename it to ".env"
# 2. Fill in your keys after the equals sign (no quotes, no spaces)
# 3. Save the file
# 4. Never commit your .env to GitHub (already in .gitignore)
#
# Get your keys here:
# Helius:      https://www.helius.dev
# Pump Portal: https://pumpportal.fun
# Phantom:     https://phantom.app
#
# ============================================

# ── Helius (free tier works) ─────────────────
HELIUS_API_KEY=paste_your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=paste_your_helius_api_key_here
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=paste_your_helius_api_key_here

# ── Pump Portal (for pump.fun trades) ────────
PUMPPORTAL_API_KEY=paste_your_pumpportal_api_key_here

# ── Wallet (the one Pump Portal generated) ───
WALLET_PUBLIC_KEY=paste_your_wallet_public_address_here
WALLET_PRIVATE_KEY=paste_your_wallet_private_key_here
